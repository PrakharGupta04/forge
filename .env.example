POSTGRES_USER=forge
POSTGRES_PASSWORD=forgepassword
POSTGRES_DB=forge

# PostgreSQL connection pool sizing for forge.server.db.Database.
# DB_POOL_MIN: connections opened eagerly at Database() construction.
# DB_POOL_MAX: hard cap; getconn() blocks once every connection is in use.
# Defaults (2/10) suit a single FastAPI worker; raise both for higher
# concurrency, lower DB_POOL_MIN to reduce idle connection cost.
DB_POOL_MIN=2
DB_POOL_MAX=10

REDIS_URL=redis://redis:6379

GROQ_API_KEY=
LLM_PROVIDER=groq

ENVIRONMENT=development
LOG_LEVEL=INFO

