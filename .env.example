POSTGRES_USER=forge
POSTGRES_PASSWORD=forgepassword
POSTGRES_DB=forge

# PostgreSQL connection pool sizing for forge.server.db.Database.
# DB_POOL_MIN: connections opened eagerly at Database() construction.
# DB_POOL_MAX: hard cap; getconn() blocks once every connection is in use.
# Defaults (2/10) suit a single FastAPI worker; raise both for higher
# concurrency, lower DB_POOL_MIN to reduce idle connection cost.
DB_POOL_MIN=2
DB_POOL_MAX=10

# Docker Compose (api service on the compose network): redis://redis:6379
# Local uvicorn on the host (redis port published to localhost): redis://localhost:6379
REDIS_URL=redis://redis:6379
# Cap connect/PING time so GET /health stays fast when REDIS_URL is unreachable.
REDIS_SOCKET_CONNECT_TIMEOUT=2
REDIS_SOCKET_TIMEOUT=2
REDIS_HEALTH_PROBE_TIMEOUT=3

GROQ_API_KEY=
LLM_PROVIDER=groq

ENVIRONMENT=development
LOG_LEVEL=INFO

